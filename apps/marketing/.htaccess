# Perfume Aura marketing public_html — block monorepo source leak (SEC-7)
# SOURCE OF TRUTH: apps/marketing/.htaccess
# Publish to repo root via: pnpm marketing:sync
# Classic Git deploys whole monorepo into public_html; deny non-marketing paths.
#
# Belt-and-suspenders: FilesMatch works even if mod_rewrite is off.
# FilesMatch matches basenames only (not full paths). Tree denies need RewriteRule.

# Extra belt: deny directory indexes
Options -Indexes

# --- Authz belt (no rewrite required; basename matches) ---
<IfModule mod_authz_core.c>
  # Default allow for marketing static (index.html, styles.css, assets)
  Require all granted

  # Deny env / secret filenames if ever present
  <FilesMatch "^\.env">
    Require all denied
  </FilesMatch>
  <FilesMatch "^\.envrc$">
    Require all denied
  </FilesMatch>
  <FilesMatch "\.(pem|key)$">
    Require all denied
  </FilesMatch>
  <FilesMatch "^(id_rsa|id_ed25519)$">
    Require all denied
  </FilesMatch>

  # Deny VCS + ignore/layout disclosure
  <FilesMatch "^(\.gitignore|\.gitattributes|\.gitmodules|\.npmrc|\.nvmrc)$">
    Require all denied
  </FilesMatch>

  # Deny monorepo manifests at any depth (basename)
  <FilesMatch "^(package\.json|pnpm-lock\.yaml|pnpm-workspace\.yaml|skills-lock\.json)$">
    Require all denied
  </FilesMatch>

  # Deny markdown / agent docs
  <FilesMatch "\.(md|MD)$">
    Require all denied
  </FilesMatch>
</IfModule>

# Apache 2.2 fallback (rare on Hostinger; harmless if unused)
<IfModule !mod_authz_core.c>
  <FilesMatch "^\.env">
    Order allow,deny
    Deny from all
  </FilesMatch>
  <FilesMatch "\.(pem|key|md)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>

# --- Rewrite belt (path trees + deep patterns) ---
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block monorepo / tooling / VCS trees
  RewriteRule ^(apps|packages|docs|scripts|taskplane-tasks|\.agents|\.pi|\.github|\.git|\.neon|\.claude)(/|$) - [F,L]

  # Block lockfiles, workspace, agent, and package manifests at web root
  RewriteRule ^(package\.json|pnpm-lock\.yaml|pnpm-workspace\.yaml|skills-lock\.json)$ - [F,L]
  RewriteRule ^(AGENTS\.md|README\.md|CLAUDE\.md|TODO\.md)$ - [F,L]
  RewriteRule ^.*\.md$ - [F,L]

  # Block ignore / tooling disclosure at web root
  RewriteRule ^(\.gitignore|\.gitattributes|\.gitmodules|\.npmrc|\.nvmrc)$ - [F,L]

  # Block common secret / env patterns (per-dir match: NO leading slash)
  RewriteRule (^|/)\.env(\.|$) - [F,L]
  RewriteRule (^|/)\.envrc$ - [F,L]
  RewriteRule \.(pem|key)$ - [F,L]
  RewriteRule (^|/)(id_rsa|id_ed25519)$ - [F,L]
</IfModule>
