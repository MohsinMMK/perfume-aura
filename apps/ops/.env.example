# Neon Postgres (pooled for app runtime)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Direct connection for drizzle-kit migrations
DATABASE_URL_DIRECT=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Better Auth (openssl rand -base64 32) — min 32 characters, high entropy
BETTER_AUTH_SECRET=generate-a-long-random-string-at-least-32-chars
# App origin — local dev or https://app.perfumeaura.com in production
BETTER_AUTH_URL=http://localhost:3000
# Optional: same value for browser client when origin differs
# NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
# Optional comma-separated extra CSRF trusted origins (baseURL is always included)
# BETTER_AUTH_TRUSTED_ORIGINS=https://app.perfumeaura.com

# Seed the single owner (disableSignUp: true — no public registration)
# Run: pnpm --filter @perfume-aura/ops seed:owner
# Password must be at least 12 characters (auth minPasswordLength)
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change-me-to-a-strong-password

# Optional multi-instance Server Actions crypto (production)
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
